{
  "name": "library-management",
  "version": "1.0.0",
  "description": "",
  "main": "index.ts",
  "scripts": {
    "build": "tsc",
    "start-infra": "docker compose --env-file .env up -d",
    "dev": "npx tsx watch --clear-screen=false src/index.ts",
    "migration:generate": "npx ts-node ./node_modules/typeorm/cli.js migration:generate -d ./src/datasource.config.ts",
    "migration:up": "npx ts-node ./node_modules/typeorm/cli.js migration:run -d ./src/datasource.config.ts",
    "migration:down": "npx ts-node ./node_modules/typeorm/cli.js migration:revert -d ./src/datasource.config.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "",
  "license": "ISC",
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node"
  },
  "dependencies": {
    "class-validator": "^0.14.1",
    "cookie-parser": "~1.4.4",
    "debug": "~2.6.9",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "http-errors": "~1.6.3",
    "jade": "~1.11.0",
    "joi": "^17.13.3",
    "morgan": "~1.9.1",
    "pg": "^8.13.1",
    "redis": "^4.7.0",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^0.3.20",
    "typeorm-extension": "^3.6.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/http-errors": "^2.0.4",
    "@types/node": "^22.10.5",
    "@types/yargs": "^17.0.33",
    "nodemon": "^3.1.9",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
